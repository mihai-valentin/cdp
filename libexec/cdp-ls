#!/usr/bin/env bash
# libexec/cdp-ls — list configured projects, TAB-separated.
# TTY: emit a header row. Non-TTY: data only (script-friendly).

set -euo pipefail
shopt -s inherit_errexit

_CDP_LIB="${CDP_LIB:-$(cd -- "$(dirname -- "$0")/../lib" && pwd)}"

# shellcheck source=lib/log.sh
source "${_CDP_LIB}/log.sh"
# shellcheck source=lib/config.sh
source "${_CDP_LIB}/config.sh"

if [[ $# -ne 0 ]]; then
    CDP_DIE_EXIT=64 cdp_die "ls: takes no arguments"
fi

config_path="$(cdp_config_path)"
if [[ ! -e "$config_path" ]]; then
    exit 0
fi

cdp_config_parse "$config_path"

if [[ "${#CDP_PROJECTS[@]}" -eq 0 ]]; then
    exit 0
fi

if [[ -t 1 ]]; then
    printf 'LABEL\tPATH\tACTIONS\n'
fi

# Sort labels deterministically.
labels=()
while IFS= read -r l; do
    labels+=("$l")
done < <(printf '%s\n' "${!CDP_PROJECTS[@]}" | LC_ALL=C sort)

for label in "${labels[@]}"; do
    path="${CDP_PATHS[$label]}"
    # Walk CDP_ACTION_ORDER so actions print in source order, filtering by
    # this project. Each entry becomes "<name>:<kind>" so consumers can tell
    # macros from tmux blocks at a glance.
    actions=()
    if [[ "${#CDP_ACTION_ORDER[@]}" -gt 0 ]]; then
        for key in "${CDP_ACTION_ORDER[@]}"; do
            if [[ "${key%%$'\x1f'*}" == "$label" ]]; then
                actions+=("${key#*$'\x1f'}:${CDP_ACTIONS[$key]}")
            fi
        done
    fi
    actions_csv=""
    if [[ "${#actions[@]}" -gt 0 ]]; then
        actions_csv="$(IFS=,; printf '%s' "${actions[*]}")"
    fi
    printf '%s\t%s\t%s\n' "$label" "$path" "$actions_csv"
done
