#!/usr/bin/env bash
# libexec/cdp-resolve — resolve <label> [<macro>] into a CDP_CD/CDP_RUN plan.
# stdout is consumed by the shell shim; stderr carries human-readable errors.

set -euo pipefail

_CDP_LIB="${CDP_LIB:-$(cd -- "$(dirname -- "$0")/../lib" && pwd)}"

# shellcheck source=lib/log.sh
source "${_CDP_LIB}/log.sh"
# shellcheck source=lib/config.sh
source "${_CDP_LIB}/config.sh"

if [[ $# -lt 1 ]]; then
    CDP_DIE_EXIT=64 cdp_die "too many arguments"
fi
if [[ $# -gt 2 ]]; then
    CDP_DIE_EXIT=64 cdp_die "too many arguments"
fi

label="$1"

cdp_config_load_or_die

if [[ -z "${CDP_PROJECTS[$label]+x}" ]]; then
    cdp_die "unknown label or subcommand: ${label}"
fi

path="${CDP_PATHS[$label]}"

if [[ ! -d "$path" ]]; then
    cdp_die "project path does not exist: ${path}"
fi

if [[ $# -eq 1 ]]; then
    printf 'CDP_CD %s\n' "$path"
    exit 0
fi

name="$2"
key="${label}"$'\x1f'"${name}"

# V1.4 inheritance: if the project has no own action by this name, try the
# group-level macros for the project's group (if any). Project-level actions
# always shadow group-level ones — the lookup never falls through when the
# project declared the same name itself.
inherited_group=""
if [[ -z "${CDP_ACTIONS[$key]+x}" ]]; then
    group="${CDP_PROJECT_GROUP[$label]:-}"
    if [[ -n "$group" && -n "${CDP_GROUP_MACROS[${group}$'\x1f'${name}]+x}" ]]; then
        inherited_group="$group"
    else
        cdp_die "'${name}' is not a macro or tmux of project '${label}'"
    fi
fi

action_kind="${CDP_ACTIONS[$key]:-macro}"

case "$action_kind" in
    macro)
        printf 'CDP_CD %s\n' "$path"
        if [[ -n "$inherited_group" ]]; then
            arr_name="CDP_GROUP_RUNS_${inherited_group//-/_}_${name//-/_}"
        else
            arr_name="CDP_RUNS_${label//-/_}_${name//-/_}"
        fi
        # Indirect array expansion for a dynamic name.
        # shellcheck disable=SC2154,SC2294
        eval "runs=(\"\${${arr_name}[@]}\")"
        # shellcheck disable=SC2154 # populated via the eval above
        for cmd in "${runs[@]}"; do
            printf 'CDP_RUN %s\n' "$cmd"
        done
        ;;
    tmux)
        layout="${CDP_TMUX_LAYOUTS[$key]}"
        # Walk the layout to derive pane order. cdp_tmux_layout_parse was
        # already run successfully at parse time, so re-running here is
        # purely to populate CDP_TMUX_LAYOUT_PANES in this process.
        cdp_tmux_layout_parse "$layout"

        printf 'CDP_CD %s\n' "$path"
        printf 'CDP_TMUX_SESSION %s-%s\n' "$label" "$name"
        printf 'CDP_TMUX_LAYOUT %s\n' "$layout"

        for pane in "${CDP_TMUX_LAYOUT_PANES[@]}"; do
            arr_name="CDP_TMUX_PANE_RUNS_${label//-/_}_${name//-/_}_${pane//-/_}"
            # shellcheck disable=SC2154,SC2294
            eval "runs=(\"\${${arr_name}[@]}\")"
            for cmd in "${runs[@]}"; do
                printf 'CDP_TMUX_PANE %s\x1f%s\n' "$pane" "$cmd"
            done
        done

        printf 'CDP_TMUX_ATTACH\n'
        ;;
    *)
        # Unreachable — parser only writes "macro" or "tmux".
        cdp_die "internal error: unknown action kind '${CDP_ACTIONS[$key]}' for '${label} ${name}'"
        ;;
esac
