#!/usr/bin/env bash
# libexec/cdp-help — print V1 usage and exit 0.

set -euo pipefail

cat <<'USAGE'
cdp — change-dir-project: jump to project directories, run per-project macros
                          or materialize per-project tmux layouts.

Usage:
  cdp <label>                  Jump to the project's path.
  cdp <label> <macro>          Jump, then run the macro's commands.
  cdp <label> <tmux-name>      Jump, then materialize the named tmux layout
                               (or attach if the session already exists).
  cdp add <label> <path>       Add a project entry to the config.
  cdp rm <label>               Remove a project entry.
  cdp ls                       List configured projects.
                               Output is TAB-separated: LABEL, PATH, ACTIONS.
                               ACTIONS is a comma-separated list of
                               <name>:<kind> entries (kind = macro | tmux),
                               in source order. Pipe to `column -t -s$'\t'`
                               for a human-readable view.
  cdp edit                     Open the config file in $VISUAL / $EDITOR
                               (falling back to vi). Useful for adding
                               Macro / Tmux blocks, which have no
                               dedicated subcommand in V1.
  cdp check                    Parse the config file and report whether
                               it is valid. Exit 0 on success, 2 if the
                               file is missing/unreadable, 65 on parse
                               error. Pair with `cdp edit` for a quick
                               edit-then-validate loop.
  cdp init bash | zsh          Print the shell-shim function source.
                               Add to your rc file: eval "$(cdp init bash)"
  cdp --help                   This message.
  cdp --version                Print the cdp version.

Config file:
  Searched in order: $CDP_CONFIG, $XDG_CONFIG_HOME/cdp/config,
  $HOME/.config/cdp/config. See docs/specs/config-format.md for the macro
  grammar and docs/specs/tmux-layout.md for the tmux/layout grammar.
USAGE
