#!/usr/bin/env bash
# libexec/cdp-init — emit the shell-shim function source.
# The shim wraps bin/cdp so its CDP_CD/CDP_RUN plans (for label and
# label+macro invocations) execute in the user's interactive shell.
# Subcommands (add / rm / ls / init / help / version) bypass the
# capture and run with stdout connected to the terminal.

set -euo pipefail
shopt -s inherit_errexit

_CDP_LIB="${CDP_LIB:-$(cd -- "$(dirname -- "$0")/../lib" && pwd)}"
_CDP_LIBEXEC="${CDP_LIBEXEC:-$(cd -- "$(dirname -- "$0")" && pwd)}"
_CDP_BIN="${CDP_BIN:-$(cd -- "$(dirname -- "$0")/../bin" && pwd)/cdp}"
_CDP_TMUX="${CDP_TMUX:-${_CDP_LIBEXEC}/cdp-tmux}"

# shellcheck source=lib/log.sh
source "${_CDP_LIB}/log.sh"

if [[ $# -ne 1 ]]; then
    CDP_DIE_EXIT=64 cdp_die "'init' takes one argument: bash | zsh"
fi

case "$1" in
    bash|zsh) ;;
    *)
        CDP_DIE_EXIT=64 cdp_die "'init' takes one argument: bash | zsh"
        ;;
esac

# Heredoc with ${_CDP_BIN} and ${_CDP_TMUX} interpolated at emit time. All
# other $-references are escaped so they remain literal in the user's shell.
#
# The read loop is wrapped in `{ … } 9<&0` to preserve the user's real
# stdin (the controlling terminal) on fd 9. Inside the loop, `done
# <<<"$plan"` shadows fd 0 with the here-string so we can iterate plan
# lines, but cdp-tmux needs a real terminal fd on stdin so its eventual
# `tmux attach` can open the controlling tty cleanly. We hand it fd 9
# via `<&9`, which is a duplicate of the original terminal fd — no
# /dev/tty open from us (some platforms, notably WSL2, reject tmux's
# subsequent use of /dev/tty when we've opened it first).
cat <<CDP_SHIM_EOF
cdp() {
    case "\${1:-}" in
        ''|help|--help|-h|version|--version|-v|add|rm|ls|init)
            command '${_CDP_BIN}' "\$@"
            return \$?
            ;;
    esac
    local plan rc line
    local _cdp_tmux_session="" _cdp_tmux_layout=""
    local -a _cdp_tmux_panes=()
    plan="\$(command '${_CDP_BIN}' "\$@")"
    rc=\$?
    if [[ \$rc -ne 0 ]]; then
        return \$rc
    fi
    {
        while IFS= read -r line; do
            case "\$line" in
                'CDP_CD '*)
                    cd "\${line#CDP_CD }" || return \$?
                    ;;
                'CDP_RUN '*)
                    eval "\${line#CDP_RUN }" || return \$?
                    ;;
                'CDP_TMUX_SESSION '*)
                    _cdp_tmux_session="\${line#CDP_TMUX_SESSION }"
                    ;;
                'CDP_TMUX_LAYOUT '*)
                    _cdp_tmux_layout="\${line#CDP_TMUX_LAYOUT }"
                    ;;
                'CDP_TMUX_PANE '*)
                    _cdp_tmux_panes+=("\${line#CDP_TMUX_PANE }")
                    ;;
                'CDP_TMUX_ATTACH')
                    '${_CDP_TMUX}' "\$_cdp_tmux_session" "\$_cdp_tmux_layout" "\${_cdp_tmux_panes[@]}" <&9
                    return \$?
                    ;;
                '')
                    ;;
                *)
                    printf 'cdp: malformed plan line: %s\n' "\$line" >&2
                    return 70
                    ;;
            esac
        done <<<"\$plan"
    } 9<&0
}
CDP_SHIM_EOF
